# Test Paystack only
# PAYSTACK_SECRET_KEY="sk_test_..."

# Admin alerts for staging channel
# ADMIN_WEBHOOK_URL=""

# Cron (optional)
# CRON_SECRET="staging-cron-secret"

# Email (Resend) for password reset + order alerts
# RESEND_API_KEY=""
# NOTIFY_FROM_EMAIL="Nexora Staging <orders@yourdomain.com>"
