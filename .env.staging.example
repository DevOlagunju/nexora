# Staging - do not point production wallets here

# Use a separate SQLite or Postgres database
DATABASE_URL="file:./prisma/staging.db"
# DATABASE_URL="postgresql://nexora:nexora@localhost:5432/nexora_staging"

AUTH_SECRET="staging-only-long-random-string-at-least-32-chars"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
ADMIN_EMAIL="staging-admin@example.com"
ADMIN_PASSWORD="StagingOnly!ChangeMe"
NEXT_PUBLIC_APP_NAME="Nexora Staging"
NEXT_PUBLIC_SUPPORT_WHATSAPP="2347032743929"

PLATFORM_BANK_NAME="Staging Bank"
PLATFORM_BANK_ACCOUNT="0000000000"
