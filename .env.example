# Copy to `.env` and replace every value before running or deploying.
# Never commit the real `.env` file.

# Local SQLite
DATABASE_URL="file:./prisma/dev.db"
# Production Postgres (docker-compose):
# DATABASE_URL="postgresql://nexora:nexora@localhost:5432/nexora"

AUTH_SECRET="replace-with-long-random-string-at-least-32-chars"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
NEXT_PUBLIC_APP_NAME="Nexora"
NEXT_PUBLIC_SUPPORT_WHATSAPP="2348000000000"

# Buy-crypto NGN desk account (shown to customers)
PLATFORM_BANK_NAME="Your Bank"
PLATFORM_BANK_ACCOUNT="0123456789"
PLATFORM_BANK_ACCOUNT_NAME="Nexora Limited"

# Optional: Slack/Discord webhook for desk alerts
# ADMIN_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Optional: Paystack Transfers for NGN sell payouts
# PAYSTACK_SECRET_KEY="sk_test_..."
# PAYSTACK_DEFAULT_BANK_CODE="058"

# Optional: KYC provider (default = manual desk review)
# KYC_PROVIDER="manual"
# KYC_API_KEY=""
