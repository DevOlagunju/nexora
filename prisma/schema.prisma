// Nexora  -  Nigeria crypto & gift card exchange
// Hybrid ops: admin-verified trades + structured automation hooks

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum AssetKind {
  CRYPTO
  GIFTCARD
}

enum TradeSide {
  SELL
  BUY
}

enum OrderStatus {
  DRAFT
  AWAITING_DEPOSIT
  UNDER_REVIEW
  APPROVED
  PAYOUT_SENT
  COMPLETED
  REJECTED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kyc                 KycProfile?
  cryptoOrders        CryptoOrder[]
  giftOrders          GiftCardOrder[]
  auditLogs           AuditLog[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipHash    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  bvnLast4      String?
  ninLast4      String?
  bankName      String?
  accountNumber String?
  accountName   String?
  status        KycStatus @default(UNVERIFIED)
  reviewNote    String?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rate {
  id          String    @id @default(cuid())
  kind        AssetKind
  symbol      String
  displayName String
  /// NGN per 1 unit (crypto coin or $1 gift card face value)
  sellRateNgn Float
  buyRateNgn  Float
  minAmount   Float     @default(1)
  maxAmount   Float?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([kind, symbol])
}

model PlatformWallet {
  id        String   @id @default(cuid())
  symbol    String   @unique
  network   String
  address   String
  isActive  Boolean  @default(true)
  /// Ops allowlist note (e.g. "TRC20 only - verify memo")
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CryptoOrder {
  id                 String      @id @default(cuid())
  reference          String      @unique
  userId             String
  symbol             String
  network            String
  side               TradeSide
  amountCrypto       Float
  rateNgn            Float
  amountNgn          Float
  depositAddress     String?
  /// Where we send crypto when user is buying
  userReceiveAddress String?
  txHash             String?
  bankName           String?
  accountNumber      String?
  accountName        String?
  /// User bank payment reference when buying with NGN
  paymentRef         String?
  status             OrderStatus @default(AWAITING_DEPOSIT)
  adminNote          String?
  payoutRef          String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  completedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GiftCardOrder {
  id                 String      @id @default(cuid())
  reference          String      @unique
  userId             String
  brand              String
  country            String      @default("USA")
  faceValueUsd       Float
  rateNgn            Float
  amountNgn          Float
  /// AES-GCM ciphertext  -  never store raw gift card codes
  cardCodeEncrypted  String
  cardCodeIv         String
  imageNote          String?
  status             OrderStatus @default(UNDER_REVIEW)
  adminNote          String?
  payoutRef          String?
  bankName           String?
  accountNumber      String?
  accountName        String?
  /// Auto heuristics for desk (high face, burst volume, etc.)
  fraudFlag          Boolean     @default(false)
  fraudNote          String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  completedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  meta      String?
  ipHash    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
